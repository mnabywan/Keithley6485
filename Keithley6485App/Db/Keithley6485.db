record(waveform, "$(P)$(R)IDN"){
    field(DESC, "Identification string")
    field(DTYP, "stream")
    field(INP,  "@$(PROTO_FILE) getIDN(119) $(PORT)")
    field(PINI, "YES")
    field(FTVL, "CHAR")
    field(NELM, "120")
}

# Zero check
record(bo, "$(P)$(R)ZeroCheck") {
    field(DESC, "Set auto range")
    field(DTYP, "stream")
    field(OUT,  "@$(PROTO_FILE) setZeroCheck $(PORT)")
    field(ZNAM, "Off")
    field(ONAM, "On")
    field(FLNK, "$(P)$(R)ZeroCheck-RB")
}

record(bi, "$(P)$(R)ZeroCheck-RB") {
    field(DESC, "Get zero check")
    field(DTYP, "stream")
    field(INP,  "@$(PROTO_FILE) getZeroCheck $(PORT)")
    field(ZNAM, "Off")
    field(ONAM, "On")
    field(PINI, "YES")
}

# Auto range
record(bo, "$(P)$(R)AutoRange") {
    field(DESC, "Set auto range")
    field(DTYP, "stream")
    field(OUT,  "@$(PROTO_FILE) setAutoRange $(PORT)")
    field(ZNAM, "Fixed")
    field(ONAM, "Auto")
    field(FLNK, "$(P)$(R)AutoRange-RB")
}

record(bi, "$(P)$(R)AutoRange-RB") {
    field(DESC, "Get auto range")
    field(DTYP, "stream")
